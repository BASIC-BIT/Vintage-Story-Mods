# Example environment variables for local dev tooling.
#
# Copy to `.env` (gitignored) and fill in real values.

# --- Build (local) ---

# Point to your Vintage Story install folder (contains game DLLs)
VINTAGE_STORY=D:/Games/Vintagestory

# Optional: location of additional VS profiles used by vsdev_* tools
VS_PROFILES_DIR=D:/Games/VSProfiles

# --- Pterodactyl (ptero_* OpenCode tools) ---

# Panel base URL (no trailing slash)
PTERO_BASE_URL=https://panel.example.com

# Client API token (keep private). Must be a Client key (prefix: ptlc_)
PTERO_TOKEN=ptlc_REPLACE_ME

# Optional: Application (admin) API token (prefix: ptla_)
# Used by ptero_app_* tools for creating/cloning servers, etc.
PTERO_TOKEN_APPLICATION=ptla_REPLACE_ME

# Server identifier (short string) used in /api/client/servers/{identifier}/...
# Not the numeric server id used by /api/application.
PTERO_SERVER_ID=REPLACE_ME

# Destructive gates (uploads/restarts). Keep disabled by default.
PTERO_ALLOW_FILES=0
PTERO_ALLOW_POWER=0

# Destructive gate for Application API write operations (server creation, env changes, etc.).
PTERO_APP_ALLOW_WRITE=0

# Optional: allow non-server Application API reads (defaults to a safe allowlist).
PTERO_APP_ALLOW_ALL_READ=0

# --- thebasics scripts (optional) ---

# Choose a specific env file for scripts (useful for test vs prod)
# THEBASICS_ENV_PATH=.env.test

# Enable SFTP upload in mods-dll/thebasics/scripts/package.ps1
THEBASICS_ENABLE_SFTP_UPLOAD=0

# Semicolon-separated list of local Mods folders to deploy into
# THEBASICS_LOCAL_MOD_DIRS=C:/Users/steve/AppData/Roaming/VintagestoryData/Mods;D:/Games/VSProfiles/Profile2/Mods
